{
    "layer": "bottom",
    "position": "bottom",
    "height": 40,
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    "modules-right": [
        "battery",
        "wireplumber",
        "clock"
    ],
    "clock": {
        "format": "{:%Y/%m/%d  %H:%M}",
        "format-alt": "{:%a %b %d  %I:%M %p}"
    },
    "wireplumber": {
        "format": " {volume}%",
        "format-muted": " {volume}%"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""]
    },
    "battery#bat2": {
        "bat": "BAT2"
    }
}
